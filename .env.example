# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=

# Telegram (shared)
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_TOPICS_PATH=data/telegram_topics.json

# Feishu (shared)
FEISHU_ENABLED=true

# Database
DB_PATH=data/releases.db

# Logging
LOG_LEVEL=INFO

# ── Release 数据源 ──
RELEASE_ENABLED=true
# RELEASE_FETCH_INTERVAL_MINUTES=30
# RELEASE_DIGEST_HOUR_UTC=1
# MAX_RELEASES_PER_VENDOR=1

# Vendor Tiers (JSON arrays)
# VENDORS_T0=["openai","anthropic","google"]
# VENDORS_T1=["xai","meta","deepseek","qwen","minimax","zai","volcengine","cursor"]
# VENDORS_T2=["vercel"]

# Release 通知频道
FEISHU_RELEASE_WEBHOOK_URL=

# ── Sitemap 数据源 ──
SITEMAP_ENABLED=true
# SITEMAP_CONFIG_PATH=config/sitemaps.yaml
# SITEMAP_FETCH_INTERVAL_MINUTES=120

# ── Blog 数据源 ──
BLOG_ENABLED=true
# BLOG_OPML_PATH=config/blogs.opml
# BLOG_FETCH_INTERVAL_MINUTES=60
# BLOG_MAX_ARTICLES_PER_FEED=5
# BLOG_DIGEST_HOUR_UTC=2

# Blog 通知频道
FEISHU_BLOG_WEBHOOK_URL=

# ── YouTube 数据源 ──
YOUTUBE_ENABLED=true

# YouTube proxy (Webshare residential rotating proxy for transcript fetching)
# YOUTUBE_PROXY_USERNAME=
# YOUTUBE_PROXY_PASSWORD=

# YouTube 通知频道
FEISHU_YOUTUBE_WEBHOOK_URL=
