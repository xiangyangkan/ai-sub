# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# OPENAI_BASE_URL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_TOPICS_PATH=data/telegram_topics.json

# Feishu
FEISHU_ENABLED=true
FEISHU_RELEASE_WEBHOOK_URL=
FEISHU_BLOG_WEBHOOK_URL=

# Database
# DB_PATH=data/releases.db

# Release Pipeline
RELEASE_ENABLED=true
# RELEASE_FETCH_INTERVAL_MINUTES=30
# RELEASE_DIGEST_HOUR_UTC=1
# MAX_RELEASES_PER_VENDOR=1

# Vendor Tiers (JSON arrays)
# VENDORS_T0=["openai","anthropic","google"]
# VENDORS_T1=["xai","meta","deepseek","qwen","minimax","zai","volcengine","cursor"]
# VENDORS_T2=["vercel"]

# Sitemap Pipeline
SITEMAP_ENABLED=true
# SITEMAP_CONFIG_PATH=config/sitemaps.yaml
# SITEMAP_FETCH_INTERVAL_MINUTES=120

# Blog Pipeline
BLOG_ENABLED=true
# BLOG_OPML_PATH=config/blogs.opml
# BLOG_FETCH_INTERVAL_MINUTES=60
# BLOG_MAX_ARTICLES_PER_FEED=1
# BLOG_DIGEST_HOUR_UTC=2

# Logging
LOG_LEVEL=INFO
